# Local UI: http://localhost:3002 (port is fixed in package.json "dev" to avoid stale /_next 404s).
#
# Supabase (browser). Add the same project URL and anon key from Supabase → Settings → API.
# Redirect URLs must include: http://localhost:3002/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# materna-api URL for the browser (Tavus proxy, etc.).
# Optional in local dev — defaults to http://localhost:4000 when unset.
# Required in production builds.
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Tavus: set TAVUS_API_KEY on materna-api only, not here.
